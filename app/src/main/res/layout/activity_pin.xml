<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bgColor"
    android:fitsSystemWindows="true"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="40dp">

    <TextView
        android:id="@+id/tvLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="monospace"
        android:letterSpacing="0.2"
        android:text="@string/app_name"
        android:textColor="?attr/textPrimary"
        android:textSize="36sp" />

    <TextView
        android:id="@+id/tvTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="60dp"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:text="@string/tagline"
        android:textColor="?attr/textFaint"
        android:textSize="11sp" />

    <!-- Animated shake container -->
    <LinearLayout
        android:id="@+id/pinInputRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:orientation="vertical">

        <EditText
            android:id="@+id/etPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@null"
            android:fontFamily="monospace"
            android:gravity="center"
            android:hint="enter PIN"
            android:inputType="textPassword"
            android:letterSpacing="0.15"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:textColor="?attr/textPrimary"
            android:textColorHint="?attr/textFaint"
            android:textSize="18sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/borderFocusColor" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:fontFamily="monospace"
        android:textColor="?attr/errorColor"
        android:textSize="13sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnUnlock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@null"
        android:fontFamily="monospace"
        android:letterSpacing="0.1"
        android:paddingHorizontal="40dp"
        android:paddingVertical="12dp"
        android:text="@string/unlock"
        android:textColor="?attr/textPrimary"
        android:textSize="13sp" />

    <View
        android:layout_width="wrap_content"
        android:layout_height="1dp"
        android:layout_marginTop="-1dp"
        android:background="?attr/borderFocusColor" />

    <!-- Hint shown after 5 wrong attempts -->
    <LinearLayout
        android:id="@+id/hintBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginTop="40dp"
        android:orientation="vertical"
        android:paddingTop="16dp"
        android:visibility="gone">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?attr/borderColor"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:gravity="center"
            android:lineSpacingMultiplier="1.4"
            android:text="Forgotten your PIN?\nA full reinstall will permanently wipe BurnerPad and all its notes. There is no other recovery option."
            android:textColor="?attr/textFaint"
            android:textSize="11sp" />
    </LinearLayout>

</LinearLayout>
