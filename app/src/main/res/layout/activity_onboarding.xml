<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bgColor"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:minHeight="@dimen/screen_min_height"
        android:orientation="vertical"
        android:paddingHorizontal="36dp"
        android:paddingVertical="60dp">

        <TextView
            android:id="@+id/tvLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:letterSpacing="0.2"
            android:text="@string/app_name"
            android:textColor="?attr/textPrimary"
            android:textSize="32sp" />

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="48dp"
            android:fontFamily="monospace"
            android:letterSpacing="0.1"
            android:textColor="?attr/textFaint"
            android:textSize="11sp" />

        <!-- STEP: welcome -->
        <LinearLayout
            android:id="@+id/stepWelcome"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                android:text="Your notes are encrypted on this device. No cloud. No tracking. No formatting. Just text."
                android:textColor="?attr/textPrimary"
                android:textSize="17sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                android:text="You'll set a PIN to open the app. Without it, your notes are unreadable — even to us."
                android:textColor="?attr/textPrimary"
                android:textSize="17sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                android:text="If you don't want a PIN, use 12345. We won't judge you."
                android:textColor="?attr/textPrimary"
                android:textSize="17sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:paddingStart="12dp"
                android:text="There is no PIN recovery. If you forget your PIN, a full reinstall is the only option — and it destroys everything."
                android:textColor="?attr/errorMutedColor"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- STEP: pin_behavior -->
        <LinearLayout
            android:id="@+id/stepPinBehavior"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                android:text="If you set your PIN to 12345, BurnerPad will open automatically without asking for a PIN each time the app launches or returns from the background."
                android:textColor="?attr/textPrimary"
                android:textSize="17sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                android:text="Any other PIN will be required every time the app opens or comes back to the foreground."
                android:textColor="?attr/textPrimary"
                android:textSize="17sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.5"
                android:text="Either way, your notes are fully encrypted. The only difference is how often you're asked to type your PIN."
                android:textColor="?attr/textPrimary"
                android:textSize="17sp" />
        </LinearLayout>

        <!-- STEP: setpin -->
        <LinearLayout
            android:id="@+id/stepSetPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:text="Choose a PIN"
                android:textColor="?attr/textFaint"
                android:textSize="11sp"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="20dp" />

            <EditText
                android:id="@+id/etPin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:fontFamily="monospace"
                android:hint="PIN (numbers, letters, symbols)"
                android:inputType="textPassword"
                android:letterSpacing="0.08"
                android:paddingVertical="10dp"
                android:textColor="?attr/textPrimary"
                android:textColorHint="?attr/textFaint"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/borderStrongColor"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:letterSpacing="0.1"
                android:text="Confirm PIN"
                android:textColor="?attr/textFaint"
                android:textSize="11sp"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="20dp" />

            <EditText
                android:id="@+id/etConfirmPin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:fontFamily="monospace"
                android:hint="repeat PIN"
                android:inputType="textPassword"
                android:imeOptions="actionGo"
                android:letterSpacing="0.08"
                android:paddingVertical="10dp"
                android:textColor="?attr/textPrimary"
                android:textColorHint="?attr/textFaint"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/borderStrongColor"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:lineSpacingMultiplier="1.4"
                android:text="Minimum 5 characters. Numbers only is fine. Letters and symbols make it stronger."
                android:textColor="?attr/textFaint"
                android:textSize="11sp"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tvError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textColor="?attr/errorColor"
                android:textSize="13sp"
                android:layout_marginTop="12dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Navigation buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@null"
                android:fontFamily="monospace"
                android:letterSpacing="0.08"
                android:paddingHorizontal="32dp"
                android:paddingVertical="14dp"
                android:text="next →"
                android:textColor="?attr/textPrimary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvSkip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:paddingVertical="4dp"
                    android:text="@string/skip"
                    android:textColor="?attr/textFaint"
                    android:textSize="11sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:fontFamily="monospace"
                    android:text="·"
                    android:textColor="?attr/textMicro"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvDeclineAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:paddingVertical="4dp"
                    android:text="@string/decline_all_tutorials"
                    android:textColor="?attr/textMicro"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
