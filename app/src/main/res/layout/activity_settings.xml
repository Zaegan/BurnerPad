<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/bgColor"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="16dp"
        android:paddingBottom="48dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.05"
            android:text="@string/back"
            android:textColor="?attr/textFaint"
            android:textSize="13sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.15"
            android:text="Settings"
            android:textColor="?attr/textMicro"
            android:textSize="13sp" />

        <!-- PIN gate (shown when locked) -->
        <LinearLayout
            android:id="@+id/pinGate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:fontFamily="sans-serif"
                android:text="Enter your PIN to continue"
                android:textColor="?attr/textPrimary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etGatePin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:fontFamily="sans-serif"
                android:hint="PIN"
                android:inputType="textPassword"
                android:imeOptions="actionGo"
                android:paddingVertical="8dp"
                android:textColor="?attr/textPrimary"
                android:textColorHint="?attr/textHint"
                android:textSize="14sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?attr/borderColor" />

            <TextView
                android:id="@+id/tvGateError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif"
                android:textColor="?attr/errorMutedColor"
                android:textSize="13sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnGateContinue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@null"
                android:fontFamily="sans-serif"
                android:letterSpacing="0.08"
                android:paddingVertical="12dp"
                android:text="continue →"
                android:textColor="?attr/textFaint"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/tvPrivacyGate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif"
                android:letterSpacing="0.08"
                android:paddingVertical="8dp"
                android:text="@string/privacy_policy"
                android:textColor="?attr/textPrimary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Settings content (shown after gate) -->
        <LinearLayout
            android:id="@+id/settingsContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Theme card -->
            <LinearLayout
                android:id="@+id/cardTheme"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="0.08"
                    android:text="Theme"
                    android:textColor="?attr/textPrimary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <TextView android:id="@+id/btnThemeDark"   android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="24dp" android:fontFamily="sans-serif" android:letterSpacing="0.08" android:paddingVertical="4dp" android:text="dark"   android:textColor="?attr/textPrimary" android:textSize="13sp" />
                    <TextView android:id="@+id/btnThemeLight"  android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="24dp" android:fontFamily="sans-serif" android:letterSpacing="0.08" android:paddingVertical="4dp" android:text="light"  android:textColor="?attr/textPrimary" android:textSize="13sp" />
                    <TextView android:id="@+id/btnThemeSystem" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif"   android:letterSpacing="0.08" android:paddingVertical="4dp" android:text="system" android:textColor="?attr/textPrimary" android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Autosave card -->
            <LinearLayout
                android:id="@+id/cardAutosave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="10dp"
                        android:fontFamily="sans-serif"
                        android:letterSpacing="0.08"
                        android:text="Autosave"
                        android:textColor="?attr/textPrimary"
                        android:textSize="14sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:lineSpacingMultiplier="1.5"
                        android:text="When on, edits are saved immediately. No recovery files are created. When off, edits go to a shadow copy until you save manually."
                        android:textColor="?attr/textFaint"
                        android:textSize="13sp" />
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchAutosave"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp" />
            </LinearLayout>

            <!-- Change PIN card -->
            <LinearLayout
                android:id="@+id/cardChangePin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:fontFamily="sans-serif" android:letterSpacing="0.08" android:text="Change PIN" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="0dp" android:fontFamily="sans-serif" android:lineSpacingMultiplier="1.5" android:text="All notes will be re-encrypted with a key derived from your new PIN. Minimum 5 characters." android:textColor="?attr/textFaint" android:textSize="13sp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="8dp" android:fontFamily="sans-serif" android:letterSpacing="0.05" android:text="Current PIN" android:textColor="?attr/textFaint" android:textSize="12sp" />
                <EditText android:id="@+id/etCurrentPin" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@null" android:fontFamily="sans-serif" android:inputType="textPassword" android:paddingVertical="8dp" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/borderColor" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="8dp" android:fontFamily="sans-serif" android:letterSpacing="0.05" android:text="New PIN" android:textColor="?attr/textFaint" android:textSize="12sp" />
                <EditText android:id="@+id/etNewPin" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@null" android:fontFamily="sans-serif" android:inputType="textPassword" android:paddingVertical="8dp" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/borderColor" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="8dp" android:fontFamily="sans-serif" android:letterSpacing="0.05" android:text="Confirm new PIN" android:textColor="?attr/textFaint" android:textSize="12sp" />
                <EditText android:id="@+id/etConfirmNewPin" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@null" android:fontFamily="sans-serif" android:inputType="textPassword" android:imeOptions="actionDone" android:paddingVertical="8dp" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/borderColor" />

                <TextView android:id="@+id/tvPinChangeError"    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:fontFamily="sans-serif" android:textColor="?attr/errorMutedColor" android:textSize="13sp" android:visibility="gone" />
                <TextView android:id="@+id/tvPinChangeProgress" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp"  android:fontFamily="sans-serif" android:textColor="?attr/textPrimary"    android:textSize="12sp" android:visibility="gone" />

                <Button android:id="@+id/btnChangePin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:background="@null" android:fontFamily="sans-serif" android:letterSpacing="0.08" android:paddingVertical="12dp" android:paddingHorizontal="20dp" android:text="change PIN" android:textColor="?attr/textFaint" android:textSize="13sp" />
            </LinearLayout>

            <!-- Backup card -->
            <LinearLayout
                android:id="@+id/cardBackup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:fontFamily="sans-serif" android:letterSpacing="0.08" android:text="Backup" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:lineSpacingMultiplier="1.5" android:text="Creates an encrypted archive saved to your Downloads folder. Use a strong password — min 12 chars, upper, lower, number, symbol." android:textColor="?attr/textFaint" android:textSize="13sp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="8dp" android:fontFamily="sans-serif" android:letterSpacing="0.05" android:text="Archive password" android:textColor="?attr/textFaint" android:textSize="12sp" />
                <EditText android:id="@+id/etExportPassword" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@null" android:fontFamily="sans-serif" android:inputType="textPassword" android:paddingVertical="8dp" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/borderColor" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="8dp" android:fontFamily="sans-serif" android:letterSpacing="0.05" android:text="Confirm password" android:textColor="?attr/textFaint" android:textSize="12sp" />
                <EditText android:id="@+id/etExportConfirm" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@null" android:fontFamily="sans-serif" android:inputType="textPassword" android:paddingVertical="8dp" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/borderColor" />

                <TextView android:id="@+id/tvExportError" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:fontFamily="sans-serif" android:textColor="?attr/errorMutedColor" android:textSize="13sp" android:visibility="gone" />
                <Button android:id="@+id/btnCreateBackup" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:background="@null" android:fontFamily="sans-serif" android:letterSpacing="0.08" android:paddingVertical="12dp" android:paddingHorizontal="20dp" android:text="create backup" android:textColor="?attr/textFaint" android:textSize="13sp" />
            </LinearLayout>

            <!-- Restore card -->
            <LinearLayout
                android:id="@+id/cardRestore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:fontFamily="sans-serif" android:letterSpacing="0.08" android:text="Restore" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:lineSpacingMultiplier="1.5" android:text="Restore notes from a BurnerPad backup archive." android:textColor="?attr/textFaint" android:textSize="13sp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="8dp" android:fontFamily="sans-serif" android:letterSpacing="0.05" android:text="Archive password" android:textColor="?attr/textFaint" android:textSize="12sp" />
                <EditText android:id="@+id/etRestorePassword" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@null" android:fontFamily="sans-serif" android:inputType="textPassword" android:imeOptions="actionDone" android:paddingVertical="8dp" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/borderColor" />

                <TextView android:id="@+id/tvRestoreError"    android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:fontFamily="sans-serif" android:textColor="?attr/errorMutedColor" android:textSize="13sp" android:visibility="gone" />
                <TextView android:id="@+id/tvRestoreProgress" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp"  android:fontFamily="sans-serif" android:textColor="?attr/textPrimary"    android:textSize="12sp" android:visibility="gone" />
                <Button android:id="@+id/btnRestore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:background="@null" android:fontFamily="sans-serif" android:letterSpacing="0.08" android:paddingVertical="12dp" android:paddingHorizontal="20dp" android:text="choose archive file" android:textColor="?attr/textFaint" android:textSize="13sp" />
            </LinearLayout>

            <!-- Duress PIN card -->
            <LinearLayout
                android:id="@+id/cardDuress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView android:id="@+id/tvDuressTitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:fontFamily="sans-serif" android:letterSpacing="0.08" android:text="Duress PIN" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:lineSpacingMultiplier="1.5" android:text="A duress PIN looks like your real PIN to anyone watching. When entered, it silently and permanently destroys all notes, then opens a blank BurnerPad as if nothing happened.\n\nMinimum 5 characters. Only set this if you understand what it does. There is no undo." android:textColor="?attr/textFaint" android:textSize="13sp" />

                <!-- Mode row (change / remove) — only shown when duress PIN exists -->
                <LinearLayout android:id="@+id/duressModeRow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:layout_marginBottom="20dp" android:orientation="horizontal" android:visibility="gone">
                    <TextView android:id="@+id/btnDuressChange" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="12dp" android:fontFamily="sans-serif" android:letterSpacing="0.05" android:text="change" android:textColor="?attr/textPrimary" android:textSize="13sp" />
                    <TextView android:id="@+id/btnDuressRemove" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:letterSpacing="0.05" android:text="remove" android:textColor="?attr/textPrimary" android:textSize="13sp" />
                </LinearLayout>

                <!-- Pin input section (hidden in remove mode) -->
                <LinearLayout android:id="@+id/duressPinSection" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="8dp" android:fontFamily="sans-serif" android:letterSpacing="0.05" android:text="Duress PIN" android:textColor="?attr/textFaint" android:textSize="12sp" />
                    <EditText android:id="@+id/etDuressPin" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@null" android:fontFamily="sans-serif" android:inputType="textPassword" android:paddingVertical="8dp" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/borderColor" />

                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="8dp" android:fontFamily="sans-serif" android:letterSpacing="0.05" android:text="Confirm duress PIN" android:textColor="?attr/textFaint" android:textSize="12sp" />
                    <EditText android:id="@+id/etConfirmDuressPin" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@null" android:fontFamily="sans-serif" android:inputType="textPassword" android:paddingVertical="8dp" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/borderColor" />
                </LinearLayout>

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:layout_marginBottom="8dp" android:fontFamily="sans-serif" android:letterSpacing="0.05" android:text="Type ONLY FOR DURESS to confirm" android:textColor="?attr/textPrimary" android:textSize="13sp" />
                <EditText android:id="@+id/etConfirmPhrase" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@null" android:fontFamily="sans-serif" android:hint="ONLY FOR DURESS" android:inputType="textCapCharacters" android:imeOptions="actionDone" android:paddingVertical="8dp" android:textColor="?attr/textPrimary" android:textColorHint="?attr/textHint" android:textSize="14sp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/borderColor" />

                <TextView android:id="@+id/tvDuressError" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:fontFamily="sans-serif" android:textColor="?attr/errorMutedColor" android:textSize="13sp" android:visibility="gone" />
                <Button android:id="@+id/btnDuressAction" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:background="@null" android:fontFamily="sans-serif" android:letterSpacing="0.08" android:paddingVertical="12dp" android:paddingHorizontal="20dp" android:text="set duress PIN" android:textColor="?attr/errorMutedColor" android:textSize="13sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:fontFamily="sans-serif" android:lineSpacingMultiplier="1.5" android:text="You cannot view the current duress PIN. To change it, set a new one. The duress PIN must differ from your real PIN." android:textColor="?attr/textMicro" android:textSize="12sp" />
            </LinearLayout>

            <!-- Rate card -->
            <LinearLayout
                android:id="@+id/cardRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:fontFamily="sans-serif" android:letterSpacing="0.08" android:text="Enjoying BurnerPad?" android:textColor="?attr/textPrimary" android:textSize="14sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="sans-serif" android:lineSpacingMultiplier="1.5" android:text="A review on the Play Store helps others find a private, no-nonsense notepad." android:textColor="?attr/textFaint" android:textSize="13sp" />
                <Button android:id="@+id/btnRate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:background="@null" android:fontFamily="sans-serif" android:letterSpacing="0.08" android:paddingVertical="12dp" android:paddingHorizontal="20dp" android:text="rate this app" android:textColor="?attr/textFaint" android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPrivacyContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif"
                android:letterSpacing="0.08"
                android:paddingVertical="8dp"
                android:text="@string/privacy_policy"
                android:textColor="?attr/textPrimary"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
