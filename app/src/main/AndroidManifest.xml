<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Only needed on API < 29 for writing to Downloads folder -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <application
        android:name=".BurnerPadApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BurnerPad">

        <!-- Entry point: silently routes to Onboarding or Pin -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.BurnerPad.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".OnboardingActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <activity
            android:name=".WalkthroughActivity"
            android:exported="false" />

        <activity
            android:name=".PinActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <activity
            android:name=".FileBrowserActivity"
            android:exported="false" />

        <activity
            android:name=".EditorActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

        <activity
            android:name=".SettingsActivity"
            android:windowSoftInputMode="adjustResize"
            android:exported="false" />

    </application>

</manifest>
